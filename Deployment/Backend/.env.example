# Backend Configuration

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_RELOAD=false

# Scheduling
BACKEND_RUN_EVERY_MINS=60
BACKEND_RUN_ON_STARTUP=true

# CORS (comma-separated origins, or * for all)
BACKEND_CORS_ORIGINS=*

# API Keys (required by fx_alphalab package)
GROQ_API_KEY=your_groq_api_key_here
FRED_API_KEY=2d5b66af8dddc54b502f40ae90d2559c

# Paths (optional - defaults to relative paths)
# BACKEND_OUTPUTS_DIR=/path/to/outputs
