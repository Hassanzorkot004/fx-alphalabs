# FX AlphaLab Frontend Configuration

# Backend connection
# You can set either VITE_BACKEND_HOST/VITE_BACKEND_PROTOCOL or the legacy VITE_API_URL/VITE_WS_URL values.
VITE_BACKEND_HOST=localhost:8080
VITE_BACKEND_PROTOCOL=http
# Optional legacy-style URLs (supported for compatibility)
# VITE_API_URL=http://localhost:8080/api
# VITE_WS_URL=ws://localhost:8080/ws/signals

# Feature flags
VITE_ENABLE_DEBUG=false
VITE_RECONNECT_DELAY=3000
