# FX AlphaLab — Environment Variables
# Copy this file to .env and fill in your values

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
FRED_API_KEY=your_fred_key_here

# ── LLM Config ───────────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Backend Config ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
RUN_EVERY_MINS=60
RUN_ON_STARTUP=true
RELOAD=false

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Paths (auto-detected if not set) ─────────────────────────────────────────
# FX_ALPHALAB_ROOT=/path/to/fx_alphalab
# OUTPUTS_DIR=/path/to/outputs
